# ==============================================================================
# HIKMARA AI - Phase 0 Environment Configurations Example
# Copy this file to '.env' and adjust standard local variables if needed.
# ==============================================================================

# 1. PLATFORM MODE
# Hikmara AI operates completely offline by default. Zero external API calls.
OFFLINE_MODE=true
DEBUG=true

# 2. RUNTIME CONFIGURATIONS
CONFIG_DIR=config
LOG_LEVEL=INFO
HIKMARA_DATABASE_PATH=database/hikmara.db
HIKMARA_LOG_PATH=logs/hikmara.log

# 3. SECURITY POLICIES
REQUIRE_CONSENT_FOR_EXECUTION=true
REQUIRE_CONSENT_FOR_DEPENDENCY=true
REQUIRE_CONSENT_FOR_FILE_WRITE=false
ENCRYPTION_ALGORITHM=Fernet

# 4. SYSTEM INFORMATION
SYSTEM_NAME="Hikmara AI"
SYSTEM_VERSION="0.1.0"

# 5. USER SETTINGS
DEFAULT_USERNAME=admin
DEFAULT_ROLE=super_user
